<Window x:Class="Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Wpf"
        mc:Ignorable="d"
        Title="MainWindow" Height="1085.617" Width="800">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="15">

            <TextBlock Text="Панель базового продукта:" FontWeight="Bold" Foreground="DarkBlue" Margin="0,0,0,5"/>
            <Border BorderBrush="LightGray" BorderThickness="1" Padding="10" Margin="0,0,0,15" Background="#FAFAFF">
                <StackPanel>
                    <TextBlock Text="Название продукта:"/>
                    <TextBox x:Name="TxtBaseName" Text="Курица" Margin="0,0,0,5"/>

                    <TextBlock Text="Белки (г):"/>
                    <TextBox x:Name="TxtBaseProteins" Text="21" Margin="0,0,0,5"/>

                    <TextBlock Text="Углеводы (г):"/>
                    <TextBox x:Name="TxtBaseCarbs" Text="1" Margin="0,0,0,5"/>

                    <TextBlock Text="Жиры (г):"/>
                    <TextBox x:Name="TxtBaseFats" Text="2" Margin="0,0,0,5"/>

                    <TextBlock Text="Категория:"/>
                    <TextBox x:Name="TxtBaseCategory" Text="Мясо" Margin="0,0,0,10"/>

                    <TextBlock Text="Действия (3 перегрузки добавления / 3 удаления):" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                    <UniformGrid Columns="2" Margin="0,0,0,5">
                        <Button Content="Добавить (Все поля) [П1]" Click="BtnAddBaseFull_Click" Margin="0,0,5,3" Height="25" Background="LightBlue"/>
                        <Button Content="Удалить (Выбранный объект) [П1]" Click="BtnDeleteBaseObj_Click" Margin="0,0,0,3" Height="25" Background="MistyRose"/>

                        <Button Content="Добавить (Только имя) [П2]" Click="BtnAddBaseName_Click" Margin="0,0,5,3" Height="25" Background="LightBlue"/>
                        <Button Content="Удалить (Выбранный индекс) [П2]" Click="BtnDeleteBaseIndex_Click" Margin="0,0,0,3" Height="25" Background="MistyRose"/>

                        <Button Content="Добавить (По умолчанию) [П3]" Click="BtnAddBaseDefault_Click" Margin="0,0,5,0" Height="25" Background="LightBlue"/>
                        <Button Content="Удалить (По тексту имени) [П3]" Click="BtnDeleteBaseName_Click" Height="25" Background="MistyRose"/>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <TextBlock Text="Панель детального продукта (класс-потомок):" FontWeight="Bold" Foreground="DarkGreen" Margin="0,0,0,5"/>
            <Border BorderBrush="LightGray" BorderThickness="1" Padding="10" Margin="0,0,0,15" Background="#FAFFFA">
                <StackPanel>
                    <TextBlock Text="Название продукта:"/>
                    <TextBox x:Name="TxtDetName" Text="Шоколад" Margin="0,0,0,5"/>

                    <TextBlock Text="Белки (г):"/>
                    <TextBox x:Name="TxtDetProteins" Text="6" Margin="0,0,0,5"/>

                    <TextBlock Text="Углеводы (г):"/>
                    <TextBox x:Name="TxtDetCarbs" Text="50" Margin="0,0,0,5"/>

                    <TextBlock Text="Жиры (г):"/>
                    <TextBox x:Name="TxtDetFats" Text="35" Margin="0,0,0,5"/>

                    <TextBlock Text="Категория:"/>
                    <TextBox x:Name="TxtDetCategory" Text="Сладости" Margin="0,0,0,5"/>

                    <TextBlock Text="Калории (Параметр P):"/>
                    <TextBox x:Name="TxtDetCalories" Text="540" Margin="0,0,0,5"/>

                    <TextBlock Text="Производитель:"/>
                    <TextBox x:Name="TxtDetManufacturer" Text="Алёнка" Margin="0,0,0,10"/>

                    <TextBlock Text="Действия (3 перегрузки добавления / 3 удаления):" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                    <UniformGrid Columns="2">
                        <Button Content="Добавить (Все поля) [П1]" Click="BtnAddDetailedFull_Click" Margin="0,0,5,3" Height="25" Background="LightGreen"/>
                        <Button Content="Удалить (Выбранный объект) [П1]" Click="BtnDeleteDetailedObj_Click" Margin="0,0,0,3" Height="25" Background="MistyRose"/>

                        <Button Content="Добавить (Имя + калории) [П2]" Click="BtnAddDetailedQuick_Click" Margin="0,0,5,3" Height="25" Background="LightGreen"/>
                        <Button Content="Удалить (По тексту имени) [П2]" Click="BtnDeleteDetailedKey_Click" Margin="0,0,0,3" Height="25" Background="MistyRose"/>

                        <Button Content="Добавить (По умолчанию) [П3]" Click="BtnAddDetailedDefault_Click" Margin="0,0,5,0" Height="25" Background="LightGreen"/>
                        <Button Content="Удалить (Выбранный индекс) [П3]" Click="BtnDeleteDetailedIndex_Click" Height="25" Background="MistyRose"/>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <TextBlock Text="Управление выводом и запросы LINQ:" FontWeight="Bold" Margin="0,0,0,5"/>
            <UniformGrid Columns="3" Margin="0,0,0,10">
                <Button Content="Фильтр: Белки > 15г" Click="BtnFilter_Click" Height="25" Margin="0,0,5,0"/>
                <Button Content="Сортировка по Q" Click="BtnSort_Click" Height="25" Margin="0,0,5,0"/>
                <Button Content="Показать все / Сброс" Click="BtnReset_Click" Height="25"/>
            </UniformGrid>

            <ListBox x:Name="LstProducts" Height="150" Background="#FFFFFF"/>
        </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
